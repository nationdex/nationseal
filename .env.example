# Discord bot token (Bot tab in the Discord Developer Portal)
BOT_TOKEN=

# Discord user IDs allowed to manage the reviewer roster (comma separated).
# These are the operators of the shared NationSeal infrastructure, NOT
# server admins. Keep this list small.
OWNER_IDS=

# Number of reviewer approvals required before a submission is enforced
# (the "2/3 multi-sig" behaviour). Must be >= 1.
REQUIRED_APPROVALS=2

# How many seconds of message history to delete when a ban is applied
# (0-604800). Leave at 0 to keep messages.
BAN_DELETE_MESSAGE_SECONDS=0

# Path to the JSON data file NationSeal uses to persist sanctions,
# reviewer rosters, and guild metadata. Defaults to ./.data/data.json.
DATABASE_PATH=./.data/data.json

# Discord bot user IDs of anti-raid / anti-nuke bots (Wick, Beemo,
# Guardian, etc.). When any of these bots is a member of a server,
# NationSeal will NOT auto-ban on join and will instead DM the guild
# owner asking them to whitelist NationSeal. Enforcement in that
# server then requires a NationSeal owner to run /sanctions
# local-enforce.
#
# Comma-separated Discord user IDs (snowflakes).
ANTIRAID_BOT_IDS=
